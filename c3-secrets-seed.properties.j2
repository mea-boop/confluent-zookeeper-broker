# ==============================================================================
# Control Center SecurePass seed file
# Written to a temp directory by Ansible — deleted after encryption.
# NEVER committed to git. NEVER written to a persistent path.
#
# The file is named control-center.properties so the CLI writes keys as:
#   control-center.properties/<property-key> = ENC[...]
# matching the ${securepass:...} refs in the real control-center.properties.
# ==============================================================================

# SSL passwords (shared across streams, connect, schema-registry, rest)
confluent.controlcenter.streams.ssl.truststore.password = {{ c3_ssl_truststore_password }}
confluent.controlcenter.streams.ssl.keystore.password = {{ c3_ssl_keystore_password }}
confluent.controlcenter.streams.ssl.key.password = {{ c3_ssl_key_password }}
confluent.controlcenter.connect.connect.ssl.truststore.password = {{ c3_ssl_truststore_password }}
confluent.controlcenter.connect.connect.ssl.keystore.password = {{ c3_ssl_keystore_password }}
confluent.controlcenter.connect.connect.ssl.key.password = {{ c3_ssl_key_password }}
confluent.controlcenter.schema.registry.ssl.truststore.password = {{ c3_ssl_truststore_password }}
confluent.controlcenter.schema.registry.ssl.keystore.password = {{ c3_ssl_keystore_password }}
confluent.controlcenter.schema.registry.ssl.key.password = {{ c3_ssl_key_password }}
confluent.controlcenter.rest.ssl.truststore.password = {{ c3_ssl_truststore_password }}
confluent.controlcenter.rest.ssl.keystore.password = {{ c3_ssl_keystore_password }}
confluent.controlcenter.rest.ssl.key.password = {{ c3_ssl_key_password }}

# MDS basic auth (user:password format)
confluent.metadata.basic.auth.user.info = {{ c3_service_user }}:{{ c3_service_password }}
