# ==============================================================================
# SecurePass seed file — plaintext secrets for confluent secret file encrypt
# Written by Ansible to a temp directory, deleted after encryption.
# NEVER committed to git. NEVER written to a persistent path.
# ==============================================================================

# Global SSL
ssl.truststore.password = {{ ssl_truststore_password }}
ssl.keystore.password = {{ ssl_keystore_password }}
ssl.key.password = {{ ssl_key_password }}

# SASL_SSL listener JAAS
listener.name.sasl_ssl.scram-sha-256.sasl.jaas.config = {{ listener_name_sasl_ssl_scram_sha_256_sasl_jaas_config }}

# TOKEN listener SSL
listener.name.token.ssl.truststore.password = {{ ssl_truststore_password }}
listener.name.token.ssl.keystore.password = {{ ssl_keystore_password }}
listener.name.token.ssl.key.password = {{ ssl_key_password }}

# TOKEN OAuthBearer JAAS
listener.name.token.oauthbearer.sasl.jaas.config = {{ listener_name_token_oauthbearer_sasl_jaas_config }}

# AD listener SSL
listener.name.ad.ssl.truststore.password = {{ ssl_truststore_password }}
listener.name.ad.ssl.keystore.password = {{ ssl_keystore_password }}
listener.name.ad.ssl.key.password = {{ ssl_key_password }}

# MDS SSL
confluent.metadata.server.ssl.truststore.password = {{ ssl_truststore_password }}
confluent.metadata.server.ssl.keystore.password = {{ ssl_keystore_password }}
confluent.metadata.server.ssl.key.password = {{ ssl_key_password }}

# Metrics reporter
confluent.metrics.reporter.ssl.truststore.password = {{ ssl_truststore_password }}
confluent.metrics.reporter.sasl.jaas.config = {{ confluent_metrics_reporter_sasl_jaas_config }}

# Audit log exporter
confluent.security.event.logger.exporter.kafka.ssl.truststore.password = {{ ssl_truststore_password }}
confluent.security.event.logger.exporter.kafka.sasl.jaas.config = {{ confluent_security_event_logger_exporter_kafka_sasl_jaas_config }}

# LDAP
ldap.java.naming.security.credentials = {{ ldap_java_naming_security_credentials }}
ldap.ssl.truststore.password = {{ ssl_truststore_password }}

# OIDC
confluent.oidc.idp.client.secret = {{ confluent_oidc_idp_client_secret }}
