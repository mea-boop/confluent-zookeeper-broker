# ==============================================================================
# Confluent Control Center — control-center.properties
# Generated by Ansible — DO NOT EDIT MANUALLY
# Secrets are encrypted via SecurePass — plaintext is never stored here
# ==============================================================================

confluent.controlcenter.id={{ c3_id }}

# ------------------------------------------------------------------------------
# Broker connectivity
# ------------------------------------------------------------------------------
bootstrap.servers={{ c3_bootstrap_servers }}
confluent.controlcenter.streams.num.stream.threads={{ c3_stream_threads }}
confluent.controlcenter.streams.security.protocol=SASL_SSL
confluent.controlcenter.streams.ssl.truststore.location={{ c3_ssl_truststore_location }}
confluent.controlcenter.streams.ssl.truststore.password=${securepass:{{ c3_secrets_dir }}/local-secrets.properties:control-center.properties/confluent.controlcenter.streams.ssl.truststore.password}
confluent.controlcenter.streams.ssl.keystore.location={{ c3_ssl_keystore_location }}
confluent.controlcenter.streams.ssl.keystore.password=${securepass:{{ c3_secrets_dir }}/local-secrets.properties:control-center.properties/confluent.controlcenter.streams.ssl.keystore.password}
confluent.controlcenter.streams.ssl.key.password=${securepass:{{ c3_secrets_dir }}/local-secrets.properties:control-center.properties/confluent.controlcenter.streams.ssl.key.password}
confluent.controlcenter.streams.ssl.endpoint.identification.algorithm=
confluent.controlcenter.internal.topics.partitions={{ c3_internal_topics_partitions }}

# ------------------------------------------------------------------------------
# Data directory
# ------------------------------------------------------------------------------
confluent.controlcenter.data.dir={{ c3_data_dir }}

# ------------------------------------------------------------------------------
# Email alerts
# ------------------------------------------------------------------------------
confluent.controlcenter.mail.enabled={{ c3_mail_enabled | lower }}
confluent.controlcenter.mail.host.name={{ c3_mail_host }}
confluent.controlcenter.mail.port={{ c3_mail_port }}
confluent.controlcenter.mail.from={{ c3_mail_from }}

# ------------------------------------------------------------------------------
# Metadata Service (MDS)
# ------------------------------------------------------------------------------
confluent.metadata.bootstrap.server.urls={{ c3_mds_url }}
confluent.metadata.basic.auth.user.info=${securepass:{{ c3_secrets_dir }}/local-secrets.properties:control-center.properties/confluent.metadata.basic.auth.user.info}
public.key.path={{ c3_ssl_mds_public_key }}
confluent.metadata.http.auth.credentials.provider=BASIC

# ------------------------------------------------------------------------------
# Connect
# ------------------------------------------------------------------------------
confluent.controlcenter.connect.{{ c3_connect_cluster_name }}.cluster={{ c3_connect_url }}
confluent.controlcenter.connect.connect.ssl.truststore.location={{ c3_ssl_truststore_location }}
confluent.controlcenter.connect.connect.ssl.truststore.password=${securepass:{{ c3_secrets_dir }}/local-secrets.properties:control-center.properties/confluent.controlcenter.connect.connect.ssl.truststore.password}
confluent.controlcenter.connect.connect.ssl.keystore.location={{ c3_ssl_keystore_location }}
confluent.controlcenter.connect.connect.ssl.keystore.password=${securepass:{{ c3_secrets_dir }}/local-secrets.properties:control-center.properties/confluent.controlcenter.connect.connect.ssl.keystore.password}
confluent.controlcenter.connect.connect.ssl.key.password=${securepass:{{ c3_secrets_dir }}/local-secrets.properties:control-center.properties/confluent.controlcenter.connect.connect.ssl.key.password}

# ------------------------------------------------------------------------------
# Schema Registry
# ------------------------------------------------------------------------------
confluent.controlcenter.schema.registry.enable=true
confluent.controlcenter.schema.registry.url={{ c3_schema_registry_url }}
confluent.controlcenter.schema.registry.ssl.truststore.location={{ c3_ssl_truststore_location }}
confluent.controlcenter.schema.registry.ssl.truststore.password=${securepass:{{ c3_secrets_dir }}/local-secrets.properties:control-center.properties/confluent.controlcenter.schema.registry.ssl.truststore.password}
confluent.controlcenter.schema.registry.ssl.keystore.location={{ c3_ssl_keystore_location }}
confluent.controlcenter.schema.registry.ssl.keystore.password=${securepass:{{ c3_secrets_dir }}/local-secrets.properties:control-center.properties/confluent.controlcenter.schema.registry.ssl.keystore.password}
confluent.controlcenter.schema.registry.ssl.key.password=${securepass:{{ c3_secrets_dir }}/local-secrets.properties:control-center.properties/confluent.controlcenter.schema.registry.ssl.key.password}
confluent.controlcenter.schema.registry.ssl.endpoint.identification.algorithm=

# ------------------------------------------------------------------------------
# REST / UI
# ------------------------------------------------------------------------------
confluent.controlcenter.rest.listeners=https://0.0.0.0:{{ c3_rest_port }}
confluent.controlcenter.rest.ssl.truststore.location={{ c3_ssl_truststore_location }}
confluent.controlcenter.rest.ssl.truststore.password=${securepass:{{ c3_secrets_dir }}/local-secrets.properties:control-center.properties/confluent.controlcenter.rest.ssl.truststore.password}
confluent.controlcenter.rest.ssl.keystore.location={{ c3_ssl_keystore_location }}
confluent.controlcenter.rest.ssl.keystore.password=${securepass:{{ c3_secrets_dir }}/local-secrets.properties:control-center.properties/confluent.controlcenter.rest.ssl.keystore.password}
confluent.controlcenter.rest.ssl.key.password=${securepass:{{ c3_secrets_dir }}/local-secrets.properties:control-center.properties/confluent.controlcenter.rest.ssl.key.password}
confluent.controlcenter.rest.ssl.endpoint.identification.algorithm=
confluent.controlcenter.rest.authentication.method=BEARER
ssl.endpoint.identification.algorithm=

# ------------------------------------------------------------------------------
# Command topic
# ------------------------------------------------------------------------------
confluent.controlcenter.command.topic={{ c3_command_topic }}
confluent.controlcenter.command.topic.replication={{ c3_command_topic_replication }}

# ------------------------------------------------------------------------------
# SecurePass config provider
# ------------------------------------------------------------------------------
config.providers=securepass
config.providers.securepass.class=io.confluent.kafka.security.config.provider.SecurePassConfigProvider
config.providers.securepass.param.master.encryption.key={{ CONFLUENT_SECURITY_MASTER_KEY }}

# ------------------------------------------------------------------------------
# Metrics backlog
# ------------------------------------------------------------------------------
confluent.metrics.topic.skip.backlog.minutes={{ c3_metrics_topic_skip_backlog_minutes }}
confluent.monitoring.interceptor.topic.skip.backlog.minutes={{ c3_monitoring_topic_skip_backlog_minutes }}

# ------------------------------------------------------------------------------
# License
# ------------------------------------------------------------------------------
confluent.license={{ confluent_license }}
