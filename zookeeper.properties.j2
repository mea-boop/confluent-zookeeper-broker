# Zookeeper Configuration
# Generated by Ansible for {{ ansible_fqdn }}

# Data Directories
dataDir={{ zookeeper_data_dir }}
dataLogDir={{ zookeeper_log_dir }}

# Client Port
clientPort={{ zookeeper_client_port }}
maxClientCnxns={{ zookeeper_max_client_connections }}

# Timing
tickTime={{ zookeeper_tick_time }}
initLimit={{ zookeeper_init_limit }}
syncLimit={{ zookeeper_sync_limit }}

# Zookeeper Cluster Configuration
# Format: server.<id>=<fqdn>:<peer_port>:<leader_port>
# - server.: ZooKeeper cluster server entry prefix
# - <id>: ZooKeeper server ID (myid) from hostvars[host]['zookeeper_id']
# - <fqdn>: Fully Qualified Domain Name from hostvars[host]['ansible_fqdn']
# - {{ zookeeper_peer_port }}: Peer communication port
# - {{ zookeeper_leader_port }}: Leader election port
{% for host in groups['zookeeper_nodes'] %}
server.{{ hostvars[host]['zookeeper_id'] }}={{ hostvars[host]['ansible_fqdn'] }}:{{ zookeeper_peer_port }}:{{ zookeeper_leader_port }}
{% endfor %}

# Autopurge
autopurge.snapRetainCount={{ zookeeper_autopurge_snap_retain_count }}
autopurge.purgeInterval={{ zookeeper_autopurge_purge_interval }}

#Audit
audit.enable=true

# Admin Server
admin.enableServer=false
admin.serverPort={{ zookeeper_admin_server_port }}

# JMX
jmx.port={{ zookeeper_jmx_port }}

# Four Letter Words
4lw.commands.whitelist={{ zookeeper_4lw_commands_whitelist }}